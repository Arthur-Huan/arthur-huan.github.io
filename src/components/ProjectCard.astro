---
interface Props {
  slug: string;
  title: string;
  summary?: string;
  thumbnail?: string;
}
const { slug, title, summary, thumbnail } = Astro.props;
const displayTitle = title?.trim() || 'Untitled project';
---

<a class="card" href={`/projects/${slug}/`}>
  {thumbnail ? (
      <img class="thumb" src={thumbnail} alt={displayTitle} />
  ) : (
      <div class="thumb" role="img" aria-label="Thumbnail placeholder">
        <span class="thumb-label">Thumbnail</span>
      </div>
  )}
  <div class="card-body">
    <h3 class="card-title">{displayTitle}</h3>
    {summary && summary.trim().length > 0 && <p class="card-summary">{summary}</p>}
    <span class="card-link">View project →</span>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--fg);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .card:hover,
  .card:focus-visible {
    border-color: var(--primary);
    transform: translateY(-2px);
  }

  .thumb {
    aspect-ratio: 16 / 10;
    border-bottom: 1px dashed var(--border);
    background-image: repeating-linear-gradient(
      135deg,
      var(--border) 0,
      var(--border) 1px,
      transparent 1px,
      transparent 14px
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thumb-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-soft);
    background: var(--bg-raised);
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
  }

  .card-body {
    padding: 1.25rem 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
  }

  .card-summary {
    color: var(--fg-soft);
    font-size: 0.92rem;
  }

  .card-link {
    margin-top: auto;
    padding-left: 1rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.04em;
    color: var(--primary-dim);
  }
</style>
