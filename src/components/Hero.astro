---

<section class="hero">
  <div class="wrap hero-inner">
    <h1 class="hero-name">
      Arthur Huan
      <svg class="ink-stroke" viewBox="0 0 460 24" aria-hidden="true">
        <path
          d="M2 16 C 90 22, 160 4, 240 12 S 380 22, 458 8"
          fill="none"
          stroke="var(--primary)"
          stroke-width="6"
          stroke-linecap="round"
        ></path>
      </svg>
    </h1>
    <p class="hero-role">Computer science undergrad specializing in data science and bioinformatics</p>
    <p class="hero-lede">

    </p>
  </div>
</section>

<style>
  .hero {
    padding: clamp(4rem, 12vh, 7rem) 0 clamp(3rem, 8vh, 4.5rem);
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .hero-name {
    position: relative;
    display: inline-block;
    font-family: var(--font-serif), serif;
    font-weight: 600;
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    line-height: 1.05;
    width: fit-content;
  }

  .ink-stroke {
    display: block;
    width: 100%;
    height: 0.5em;
    margin-top: -0.15em;
  }

  .hero-role {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: var(--fg);
    width: 100%;
  }

  .hero-lede {
    color: var(--fg-soft);
    max-width: 46ch;
    font-size: 1rem;
  }
</style>
